# Database (Railway PostgreSQL or local)
DATABASE_URL="postgresql://user:password@localhost:5432/velora?schema=public"

# Redis (Railway or local)
REDIS_URL="redis://localhost:6379"

# AI Providers (at least ONE required for AI features)
ANTHROPIC_API_KEY=          # Direct Anthropic access (Claude models)
OPENROUTER_API_KEY=         # OpenRouter (access ALL models via single key)
GOOGLE_GENERATIVE_AI_API_KEY=  # Google AI Studio (Gemini models, free tier)

# Optional AI
OPENAI_API_KEY=             # For embeddings (text-embedding-3-small)
AI_PRIMARY_PROVIDER=        # Force primary: "anthropic" | "openrouter" | "google"

# Web
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_MAPBOX_TOKEN=

# API
PORT=4000
CORS_ORIGINS="http://localhost:3000"

# PayloadCMS
PAYLOAD_SECRET="change-me-in-production"

# Pipeline (optional, for specific data sources)
GOOGLE_PLACES_API_KEY=
UNSTRUCTURED_API_KEY=

# DataForSEO (for attorney discovery + reviews)
DATAFORSEO_LOGIN=           # API login email from dataforseo.com
DATAFORSEO_PASSWORD=         # API password from dataforseo.com

# Authentication (Clerk — https://clerk.com, free tier: 10K MAU)
# Sign up at clerk.com → Create application → Copy keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=  # pk_test_... or pk_live_...
CLERK_SECRET_KEY=                   # sk_test_... or sk_live_...

# File Storage (default: local filesystem, set to 's3' for production)
FILE_STORAGE_TYPE=local             # local | s3
S3_BUCKET=                          # e.g. velora-uploads
S3_REGION=us-east-1
PUBLIC_FILE_URL=http://localhost:4000/uploads

# Case Sharing
SHARE_LINK_SECRET=                  # Random string for HMAC token signing

# Vector Database (Qdrant Cloud — free at https://cloud.qdrant.io)
QDRANT_URL=                 # e.g. https://your-cluster-id.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=             # API key from Qdrant Cloud dashboard
