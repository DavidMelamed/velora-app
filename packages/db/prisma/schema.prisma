generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // extensions = [vector]  // Deferred to Phase 0 PGVECTOR-SETUP — requires pgvector-enabled Postgres image
}

// ╔══════════════════════════════════════════════════╗
// ║  CORE CRASH DATA (MMUCC 6th Edition Aligned)    ║
// ╚══════════════════════════════════════════════════╝

model Crash {
  id                 String  @id @default(cuid())
  stateUniqueId      String  @unique // S1
  agencyJurisdiction String? // S2
  policeReported     Boolean @default(true) // S3
  stateReportable    Boolean @default(true) // S4

  // C-series: Crash-level
  crashDate            DateTime // C1
  crashTime            String? // C2
  roadwayClearanceTime DateTime? // C3
  county               String? // C4
  latitude             Float? // C5
  longitude            Float? // C5
  firstHarmfulEvent    String? // C6
  firstHarmfulEventLoc String? // C7
  mannerOfCollision    MannerOfCollision? // C8
  atmosphericCondition AtmosphericCondition? // C9
  lightCondition       LightCondition? // C10
  relationToJunction   String? // C11
  intersectionType     String? // C12
  schoolBusRelated     Boolean               @default(false) // C13
  workZone             Json? // C14
  secondaryCrash       Boolean               @default(false) // C15
  crashRelatedFactors  String[] // C16

  // Derived
  crashSeverity CrashSeverity?
  stateCode     String // 2-letter state code
  cityName      String?
  streetAddress String?

  // Relations
  vehicles       Vehicle[]
  persons        Person[]
  narratives     CrashNarrative[]
  equalizer      CrashEqualizer?
  feedbackEvents FeedbackEvent[]

  // Case Memory
  matters Matter[]

  // Clustering
  archetypeId String?
  archetype   CrashArchetype? @relation(fields: [archetypeId], references: [id])

  // Verification
  confirmationCount Int     @default(0)
  isVerified        Boolean @default(false)

  // Metadata
  dataSource String
  rawData    Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([crashDate])
  @@index([county])
  @@index([stateCode])
  @@index([latitude, longitude])
  @@index([crashSeverity])
  @@index([dataSource])
  @@index([stateCode, crashDate])
  @@index([archetypeId])
}

model Vehicle {
  id      String @id @default(cuid())
  crashId String
  crash   Crash  @relation(fields: [crashId], references: [id], onDelete: Cascade)

  // V-series
  vin                       String? // V1
  unitTypeAndNumber         Int? // V2
  registrationState         String? // V3
  licensePlate              String? // V4
  make                      String? // V5
  modelYear                 Int? // V6
  model                     String? // V7
  bodyType                  BodyTypeCategory? // V8
  totalOccupants            Int? // V9
  specialFunction           String? // V10
  emergencyUse              Boolean           @default(false) // V11
  speedLimit                Int? // V12
  directionOfTravel         String? // V13
  trafficwayDesc            String? // V14
  totalLanes                Int? // V15
  hitAndRun                 Boolean           @default(false) // V17
  sequenceOfEvents          String[] // V18
  mostHarmfulEvent          String? // V19
  contributingCircumstances String[] // V20

  // Relations
  driver  Driver?
  persons Person[]

  @@index([crashId])
  @@index([vin])
}

model Driver {
  id        String  @id @default(cuid())
  vehicleId String  @unique
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  personId  String? @unique
  person    Person? @relation(fields: [personId], references: [id])

  // D-series (NEW in MMUCC 6th Edition)
  licenseJurisdiction    String? // D1
  licenseClass           String? // D2
  licenseStatus          String? // D3
  speedingRelated        Boolean? // D4
  driverActions          String[] // D5
  distractedBy           String? // D6
  driverCondition        String? // D7
  suspectedAlcoholDrug   Boolean? // D8
  alcoholDrugTestResults Json? // D9
  driverRelatedFactors   String[] // D10
}

model Person {
  id        String   @id @default(cuid())
  crashId   String
  crash     Crash    @relation(fields: [crashId], references: [id], onDelete: Cascade)
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  // P-series
  name                   String? // P1 (encrypted at rest, excluded from public API)
  dateOfBirth            DateTime? // P2
  sex                    Sex? // P3
  personType             PersonType // P4
  injuryStatus           InjuryStatus? // P5 (KABCO)
  motorVehicleUnitNumber Int? // P6
  seatingPosition        String? // P7
  restraintUse           String? // P8
  airBagDeployed         String? // P9
  ejection               String? // P10
  nonMotoristLocation    String? // P11
  nonMotoristAction      String? // P12
  nonMotoristCondition   String? // P13
  personRelatedFactors   String[] // P14

  // Reverse relation
  driver Driver?

  @@index([crashId])
  @@index([injuryStatus])
  @@index([personType])
}

// ╔══════════════════════════════════════════════════╗
// ║  INTELLIGENCE: Narratives, Equalizer, Attorneys  ║
// ╚══════════════════════════════════════════════════╝

model CrashNarrative {
  id      String @id @default(cuid())
  crashId String @unique
  crash   Crash  @relation(fields: [crashId], references: [id], onDelete: Cascade)

  // Structured output (10 sections)
  content Json // CrashNarrativeContent shape
  summary String // 2-3 sentence plain text summary

  // Quality metrics
  factualAccuracy  Float? // 0-1
  toneScore        Float? // 0-1
  readabilityScore Float? // Flesch-Kincaid grade level
  approvalRate     Float? // from feedback

  // Metadata
  modelTier     String // premium | standard | budget
  modelId       String // exact model used
  promptVersion String? // links to PromptVersion.id
  dataTier      String // RICH | STANDARD | MINIMAL
  generatedAt   DateTime @default(now())
  generationMs  Int? // latency tracking

  @@index([modelTier])
  @@index([dataTier])
}

model CrashEqualizer {
  id      String @id @default(cuid())
  crashId String @unique
  crash   Crash  @relation(fields: [crashId], references: [id], onDelete: Cascade)

  // Comparable Cohort
  comparableCohort Json
  confidenceLevel  String // HIGH | MEDIUM | LOW

  // Liability Signals
  liabilitySignals Json

  // Settlement Context
  settlementContext Json

  // Attorney Matches
  attorneyMatches Json

  // AI Briefing
  briefingSections Json
  disclaimer       String @default("This analysis is based on public crash data and is not legal advice.")

  // Metadata
  modelVersion String
  generatedAt  DateTime @default(now())
  generationMs Int?

  @@index([confidenceLevel])
}

model Attorney {
  id            String  @id @default(cuid())
  slug          String  @unique
  name          String
  firmName      String?
  phone         String?
  email         String?
  website       String?
  domain        String?
  googlePlaceId String? @unique
  googleCid     String? @unique

  // Location
  address     String?
  addressInfo Json? // Structured address components
  city        String?
  stateCode   String?
  zipCode     String?
  latitude    Float?
  longitude   Float?

  // Google Business Profile
  description          String?
  category             String?
  categoryIds          String[]
  additionalCategories String[]
  logoUrl              String?
  mainImageUrl         String?
  totalPhotos          Int?     @default(0)
  isClaimed            Boolean? @default(false)
  googleRating         Float?
  googleReviewCount    Int?     @default(0)
  ratingDistribution   Json? // { "1": 5, "2": 3, "3": 10, ... }
  workHours            Json?
  attributes           Json? // Business attributes from Google
  peopleAlsoSearch     Json? // Related businesses
  googleMapsUrl        String?
  contactInfo          Json? // Array of { type, value, source }

  // Specializations
  practiceAreas   String[]
  barNumber       String?
  yearsExperience Int?

  // Relations
  reviews            AttorneyReview[]
  reviewIntelligence ReviewIntelligence?
  attorneyIndex      AttorneyIndex?
  matters            Matter[]
  leads              LeadRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stateCode])
  @@index([city])
  @@index([latitude, longitude])
  @@index([googleRating])
}

model AttorneyReview {
  id         String   @id @default(cuid())
  attorneyId String
  attorney   Attorney @relation(fields: [attorneyId], references: [id], onDelete: Cascade)

  // Google review data
  googleReviewId   String?   @unique
  authorName       String?
  authorImageUrl   String?
  authorProfileUrl String?
  rating           Int // 1-5
  text             String?
  reviewUrl        String?
  publishedAt      DateTime?
  timeAgo          String?
  language         String?   @default("en")

  // Extended review fields
  isLocalGuide    Boolean? @default(false)
  photosCount     Int?     @default(0)
  images          Json? // Array of { image_url, alt }
  ownerResponse   String?
  ownerResponseAt String? // timestamp string from DataForSEO

  // Analyzed dimensions
  dimensions Json?

  createdAt DateTime @default(now())

  @@index([attorneyId])
  @@index([rating])
}

model ReviewIntelligence {
  id         String   @id @default(cuid())
  attorneyId String   @unique
  attorney   Attorney @relation(fields: [attorneyId], references: [id], onDelete: Cascade)

  // Dimension scores (0-100 each)
  communication   Float
  outcome         Float
  responsiveness  Float
  empathy         Float
  expertise       Float
  feeTransparency Float
  trialExperience Float
  satisfaction    Float

  // Trend analysis
  trend             String // IMPROVING | STABLE | DECLINING
  trendPeriodMonths Int    @default(12)

  // Pull quotes
  bestQuotes Json

  // Metadata
  reviewCount Int
  analyzedAt  DateTime @default(now())

  @@index([communication])
  @@index([outcome])
}

model AttorneyIndex {
  id         String   @id @default(cuid())
  attorneyId String   @unique
  attorney   Attorney @relation(fields: [attorneyId], references: [id], onDelete: Cascade)

  // Composite score (0-100)
  score Float

  // Component scores
  communicationScore  Float
  responsivenessScore Float
  outcomeScore        Float
  reviewCountScore    Float
  specialtyScore      Float

  // Metadata
  computedAt  DateTime @default(now())
  reviewCount Int
  dataQuality String // HIGH | MEDIUM | LOW

  @@index([score])
}

// ╔══════════════════════════════════════════════════╗
// ║  GEO & INTERSECTIONS                            ║
// ╚══════════════════════════════════════════════════╝

model GeoEntity {
  id         String        @id @default(cuid())
  type       GeoEntityType
  name       String
  stateCode  String
  countyFips String?
  cityFips   String?
  parentId   String?
  parent     GeoEntity?    @relation("GeoHierarchy", fields: [parentId], references: [id])
  children   GeoEntity[]   @relation("GeoHierarchy")
  latitude   Float?
  longitude  Float?
  population Int?

  // Legal context
  statuteOfLimitationsYears Int?
  faultType                 String?

  createdAt DateTime @default(now())

  @@unique([type, stateCode, name])
  @@index([stateCode])
  @@index([type])
}

model Intersection {
  id        String  @id @default(cuid())
  name      String
  stateCode String
  city      String?
  latitude  Float
  longitude Float

  // Safety metrics
  dangerScore    Float?
  totalCrashes   Int       @default(0)
  fatalCrashes   Int       @default(0)
  injuryCrashes  Int       @default(0)
  lastCrashDate  DateTime?
  lastComputedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([latitude, longitude])
  @@index([stateCode])
  @@index([dangerScore])
}

// ╔══════════════════════════════════════════════════╗
// ║  DATA PIPELINE                                  ║
// ╚══════════════════════════════════════════════════╝

model DataSource {
  id              String    @id @default(cuid())
  name            String    @unique
  type            String // FARS | ARCGIS | SOCRATA | PDF | MANUAL
  stateCode       String?
  endpoint        String?
  config          Json?
  isActive        Boolean   @default(true)
  lastFetchedAt   DateTime?
  lastRecordCount Int?
  errorCount      Int       @default(0)
  lastError       String?

  pipelineRuns PipelineRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

model PipelineRun {
  id           String     @id @default(cuid())
  dataSourceId String
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id])

  stage         String // BRONZE | SILVER | GOLD
  status        String // RUNNING | COMPLETED | FAILED
  recordsIn     Int       @default(0)
  recordsOut    Int       @default(0)
  recordsFailed Int       @default(0)
  errorLog      Json?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  durationMs    Int?

  @@index([dataSourceId])
  @@index([status])
  @@index([startedAt])
}

model PipelineDeadLetter {
  id           String    @id @default(cuid())
  dataSourceId String
  stage        String // BRONZE | SILVER | GOLD
  rawRecord    Json
  error        String
  errorType    String // VALIDATION | MAPPING | DUPLICATE | UNKNOWN
  retryCount   Int       @default(0)
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([dataSourceId])
  @@index([stage])
  @@index([errorType])
}

