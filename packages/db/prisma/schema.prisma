// ╔══════════════════════════════════════════════════╗
// ║  CRASH ARCHETYPES                               ║
// ╚══════════════════════════════════════════════════╝

model CrashArchetype {
  id                 String  @id @default(cuid())
  name               String
  stateCode          String?
  centroid           Json
  crashCount         Int
  avgSeverity        Float
  injuryRate         Float
  fatalityRate       Float
  seasonalPattern    Json
  definingAttributes Json
  crashes            Crash[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stateCode])
  @@index([crashCount])
}

// ╔══════════════════════════════════════════════════╗
// ║  SELF-LEARNING: Feedback, Prompts, Experiments  ║
// ╚══════════════════════════════════════════════════╝

model FeedbackEvent {
  id           String   @id @default(cuid())
  type         String
  crashId      String?
  crash        Crash?   @relation(fields: [crashId], references: [id])
  sessionId    String
  value        Json
  experimentId String?
  variant      String?
  createdAt    DateTime @default(now())

  @@index([type])
  @@index([crashId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([experimentId])
}

model FeedbackAggregate {
  id          String  @id @default(cuid())
  period      String // YYYY-MM-DD
  crashType   String?
  severity    String?
  archetypeId String?

  narrativeApprovalRate Float
  equalizerUsefulRate   Float
  avgTimeOnPage         Float
  scrollThroughRate     Float
  attorneyClickRate     Float
  sampleSize            Int

  createdAt DateTime @default(now())

  @@unique([period, crashType, severity])
  @@index([period])
}

model PromptVersion {
  id          String  @id @default(cuid())
  signature   String
  version     Int
  parentId    String?
  archetypeId String?

  promptContent  Json
  mutations      Json?
  scores         Json?
  compositeScore Float?

  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([signature, version])
  @@index([signature, isActive])
  @@index([signature, archetypeId])
}

model Experiment {
  id        String  @id @default(cuid())
  name      String
  signature String
  variants  Json
  status    String // RUNNING | COMPLETED | PROMOTED
  winnerId  String?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([status])
  @@index([signature])
}

// ╔══════════════════════════════════════════════════╗
// ║  AGENT SYSTEM                                   ║
// ╚══════════════════════════════════════════════════╝

model AgentSession {
  id         String   @id @default(cuid())
  agentId    String
  action     String
  input      Json?
  output     Json?
  status     String // SUCCESS | FAILED | SKIPPED
  durationMs Int?
  error      String?
  createdAt  DateTime @default(now())

  @@index([agentId])
  @@index([status])
  @@index([createdAt])
}

// ╔══════════════════════════════════════════════════╗
// ║  ENUMS (MMUCC 6th Edition)                      ║
// ╚══════════════════════════════════════════════════╝

enum CrashSeverity {
  FATAL
  SUSPECTED_SERIOUS_INJURY
  SUSPECTED_MINOR_INJURY
  POSSIBLE_INJURY
  PROPERTY_DAMAGE_ONLY
}

enum InjuryStatus {
  FATAL
  SUSPECTED_SERIOUS
  SUSPECTED_MINOR
  POSSIBLE
  NO_APPARENT_INJURY
}

enum MannerOfCollision {
  NOT_COLLISION_WITH_MV
  FRONT_TO_REAR
  FRONT_TO_FRONT
  ANGLE
  SIDESWIPE_SAME_DIRECTION
  SIDESWIPE_OPPOSITE_DIRECTION
  REAR_TO_SIDE
  REAR_TO_REAR
  OTHER
  UNKNOWN
}

enum AtmosphericCondition {
  CLEAR
  CLOUDY
  RAIN
  SNOW
  SLEET_HAIL_FREEZING_RAIN
  FOG_SMOG_SMOKE
  BLOWING_SNOW
  BLOWING_SAND_SOIL_DIRT
  SEVERE_CROSSWINDS
  OTHER
  UNKNOWN
}

enum LightCondition {
  DAYLIGHT
  DAWN
  DUSK
  DARK_LIGHTED
  DARK_NOT_LIGHTED
  DARK_UNKNOWN_LIGHTING
  OTHER
  UNKNOWN
}

enum PersonType {
  DRIVER
  PASSENGER
  PEDESTRIAN
  PEDALCYCLIST
  OCCUPANT_OF_NON_MV
  OTHER
  UNKNOWN
}

enum Sex {
  MALE
  FEMALE
  NOT_REPORTED
  UNKNOWN
}

enum BodyTypeCategory {
  PASSENGER_CAR
  SUV
  PICKUP
  VAN
  LIGHT_TRUCK
  MEDIUM_HEAVY_TRUCK
  TRUCK_TRACTOR
  MOTOR_HOME
  BUS_SMALL
  BUS_LARGE
  MOTORCYCLE
  MOPED
  ATV
  SNOWMOBILE
  OTHER
  UNKNOWN
}

enum GeoEntityType {
  STATE
  COUNTY
  CITY
  TRACT
}

// ╔══════════════════════════════════════════════════╗
// ║  CASE MEMORY SYSTEM                              ║
// ╚══════════════════════════════════════════════════╝

enum MatterStatus {
  INTAKE
  ACTIVE
  TREATING
  DEMAND_PREP
  LITIGATION
  SETTLED
  CLOSED
}

enum EpisodeType {
  CALL_TRANSCRIPT
  CHAT_MESSAGE
  VOICE_NOTE
  LOCATION_VISIT
  PHOTO
  DOCUMENT
  EMAIL_EXTRACT
  SYSTEM_EVENT
  CONFIRMATION_RESPONSE
}

enum CaseEntityType {
  PERSON
  ORGANIZATION
  FACILITY
  INJURY
  BODY_PART
  MEDICATION
  CLAIM
  VEHICLE_ENTITY
  POLICY
  APPOINTMENT
  EXPENSE
}

enum FactStatus {
  CANDIDATE
  CONFIRMED
  REJECTED
  SUPERSEDED
}

model Matter {
  id String @id @default(cuid())

  // Owner (Clerk user ID)
  userId String?

  // Client info (minimal — populated from extraction)
  clientName  String?
  clientPhone String?
  clientEmail String?

  // Case links
  crashId    String?
  crash      Crash?    @relation(fields: [crashId], references: [id])
  attorneyId String?
  attorney   Attorney? @relation(fields: [attorneyId], references: [id])

  // Case metadata
  status          MatterStatus @default(INTAKE)
  accidentDate    DateTime?
  stateCode       String?
  statuteDeadline DateTime?

  // Relations
  episodes       Episode[]
  entities       CaseEntity[]
  facts          CaseFact[]
  timelineEvents CaseTimeline[]
  confirmations  Confirmation[]

  // Tracking
  lastActivityAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([crashId])
  @@index([attorneyId])
  @@index([stateCode])
  @@index([lastActivityAt])
}

model Episode {
  id       String @id @default(cuid())
  matterId String
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  // Episode classification
  type  EpisodeType
  title String?

  // Content (polymorphic via type)
  textContent String?
  mediaUrl    String?
  mediaType   String?
  metadata    Json?

  // Location context
  latitude     Float?
  longitude    Float?
  locationName String?

  // Extraction state
  isProcessed       Boolean @default(false)
  extractedEntities Json?

  // Timing
  occurredAt DateTime
  duration   Int?

  createdAt DateTime @default(now())

  // Relations
  entities       CaseEntity[]   @relation("EpisodeEntities")
  facts          CaseFact[]     @relation("EpisodeFacts")
  timelineEvents CaseTimeline[]

  @@index([matterId])
  @@index([type])
  @@index([occurredAt])
  @@index([isProcessed])
  @@index([matterId, type, occurredAt])
}

model CaseEntity {
  id       String @id @default(cuid())
  matterId String
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  // Entity classification
  type           CaseEntityType
  name           String
  normalizedName String?

  // Flexible attributes (type-dependent via JSONB)
  attributes Json @default("{}")

  // Confidence & provenance
  confidence       Float    @default(0.5)
  sourceEpisodeIds String[]

  // Relations
  sourceEpisodes Episode[]  @relation("EpisodeEntities")
  facts          CaseFact[] @relation("EntityFacts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matterId])
  @@index([type])
  @@index([normalizedName])
  @@index([matterId, type])
}

model CaseFact {
  id       String @id @default(cuid())
  matterId String
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  // Fact content (subject-predicate-object triple)
  subject   String
  predicate String
  object    String

  // Temporal validity
  validFrom  DateTime
  validUntil DateTime?

  // Status & confidence
  status     FactStatus @default(CANDIDATE)
  confidence Float      @default(0.5)

  // Provenance
  sourceEpisodeIds String[]
  sourceEpisodes   Episode[]    @relation("EpisodeFacts")
  sourceEntities   CaseEntity[] @relation("EntityFacts")
  supersededById   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matterId])
  @@index([predicate])
  @@index([status])
  @@index([validFrom])
  @@index([matterId, status, validFrom])
}

model CaseTimeline {
  id       String @id @default(cuid())
  matterId String
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  // Event classification
  category    String
  title       String
  description String?

  // Timing
  occurredAt DateTime
  duration   Int?

  // Provenance
  episodeId String?
  episode   Episode? @relation(fields: [episodeId], references: [id])

  // Metadata
  metadata Json?
  isGap    Boolean @default(false)
  gapDays  Int?

  createdAt DateTime @default(now())

  @@index([matterId])
  @@index([category])
  @@index([occurredAt])
  @@index([matterId, occurredAt])
}

model Confirmation {
  id       String @id @default(cuid())
  matterId String
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  // What we're confirming
  prompt    String
  episodeId String?
  factId    String?
  entityId  String?

  // Response
  confirmed   Boolean?
  respondedAt DateTime?

  // Delivery
  notificationId String?
  sentAt         DateTime  @default(now())
  expiresAt      DateTime?

  @@index([matterId])
  @@index([confirmed])
  @@index([sentAt])
}

model Provider {
  id             String  @id @default(cuid())
  name           String
  type           String
  address        String?
  latitude       Float
  longitude      Float
  phone          String?
  npi            String?
  geofenceRadius Int     @default(100)

  // Metadata
  stateCode String?
  city      String?

  createdAt DateTime @default(now())

  @@index([latitude, longitude])
  @@index([type])
  @@index([stateCode])
}

// ╔══════════════════════════════════════════════════╗
// ║  COMMERCIAL: Lead Generation & Email Capture     ║
// ╚══════════════════════════════════════════════════╝

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  CLOSED
}

model LeadRequest {
  id         String   @id @default(cuid())
  attorneyId String
  attorney   Attorney @relation(fields: [attorneyId], references: [id])

  // Contact info
  name    String
  phone   String
  email   String?
  message String?

  // Context
  crashId  String?
  matterId String?
  source   String  @default("attorney_profile") // attorney_profile, equalizer, search

  // Status
  status LeadStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([attorneyId])
  @@index([status])
  @@index([createdAt])
}

model EmailCapture {
  id       String  @id @default(cuid())
  email    String
  source   String  @default("equalizer") // equalizer, attorney_badge, newsletter
  crashId  String?
  metadata Json?

  createdAt DateTime @default(now())

  @@unique([email, source])
  @@index([createdAt])
}
